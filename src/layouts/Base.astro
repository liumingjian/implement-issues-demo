---
import "../styles/global.css";
interface Props { title: string }
const { title } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar" aria-label="工作台导航">
        <a class="brand" href="/" aria-label="A 工作台首页"><span aria-hidden="true">A</span><strong>工作台</strong></a>
        <nav aria-label="主要导航">
          <a class="nav-current" href="/">时间线</a>
          <a href="/tags/">标签</a>
        </nav>
        <form class="search" action="/search/" role="search">
          <label for="practice-search">搜索实践</label>
          <input id="practice-search" name="q" type="search" placeholder="标题、摘要、标签或正文" />
        </form>
      </aside>
      <main id="main-content"><slot /></main>
    </div>
  </body>
</html>
