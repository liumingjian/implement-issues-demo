---
import "../styles/global.css";
interface Props { title: string }
const { title } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <main class="mx-auto max-w-3xl px-6 py-12"><slot /></main>
  </body>
</html>
