---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const practices = await getCollection("practices");
  return practices.map((practice) => ({ params: { id: practice.id }, props: { practice } }));
}

const { practice } = Astro.props;
const { Content } = await render(practice);
---
<Base title={`${practice.data.title} — AI 编程实践`}>
  <a href="/">返回首页</a>
  <article class="prose prose-slate mt-8">
    <h1>{practice.data.title}</h1>
    <time datetime={practice.data.date.toISOString()}>{practice.data.date.toISOString().slice(0, 10)}</time>
    <Content />
  </article>
</Base>
